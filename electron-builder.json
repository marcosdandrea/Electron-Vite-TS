{
  "appId": "com.marcosdandrea.boilerplate",
  "productName": "Boilerplate",
  "files": ["dist-electron", "dist-ui", ".env"],
  "extraFiles": [
    {
      "from": "resources/runtime/.config",
      "to": ".config.default"
    },
    {
      "from": "resources/runtime/database",
      "to": "database.default"
    }
  ],
  "icon": "./resources/icon/icon.ico",
  "asar": true,
  "mac": {
    "icon": "./resources/icon/icon.icns",
    "target": "dmg"
  },
  "linux": {
    "icon": "./resources/icon/icon.png",
    "target": "AppImage",
    "category": "Utility"
  },
  "win": {
    "icon": "./resources/icon/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "include": "build/installer.nsh"
  }
}
